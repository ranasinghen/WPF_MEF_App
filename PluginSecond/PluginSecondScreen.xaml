<UserControl x:Class="PluginSecond.PluginSecondScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PluginSecond">

    <UserControl.DataContext>
        <local:PluginSecondScreenModel />
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}" x:Key="HeaderTextStyle">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
        </Style>

        <Style TargetType="{x:Type Run}" x:Key="HeaderRunTextStyle">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
        </Style>

        <Style TargetType="{x:Type TextBlock}" x:Key="TitleTextStyle">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="DemiBold"/>
            <Setter Property="TextDecorations" Value="Underline"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
        </Style>
        <Style TargetType="{x:Type TextBox}" x:Key="InputTxtStyle">
            <Setter Property="Height" Value="28"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,5,5"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="LightBlue"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Validation.ErrorTemplate">
                <Setter.Value>
                    <ControlTemplate>
                        <Border BorderBrush="Red" BorderThickness="0,0,0,0.5">
                            <AdornedElementPlaceholder/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="false">
                    <Setter Property="Background" Value="LightGray"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="true">
                    <Setter Property="Background" Value="LightGray"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type Button}" x:Key="ButtonBlueStyle">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Blue"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="5" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" SnapsToDevicePixels="True"
                        Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="LightBlue"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type ToggleButton}" x:Key="SliderSwitch">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <ControlTemplate.Resources>
                            <Storyboard x:Key="OnCheckedSb" Storyboard.TargetName="SliderBdr" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                <DoubleAnimation Duration="00:00:0.2" To="12"/>
                            </Storyboard>
                            <Storyboard x:Key="OnUNCheckedSb" Storyboard.TargetName="SliderBdr" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
                                <DoubleAnimation Duration="00:00:0.2" To="0"/>
                            </Storyboard>
                        </ControlTemplate.Resources>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="baseBdr" Width="30" Height="16" CornerRadius="5" Background="WhiteSmoke" SnapsToDevicePixels="True"
                        BorderThickness="1" BorderBrush="LightGray">
                                <Border x:Name="SliderBdr" Width="13" Height="{Binding Width, RelativeSource={RelativeSource Self}}" Margin="0" 
                            CornerRadius="{Binding Width, RelativeSource={RelativeSource Self}}" 
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Center"
                            Background="White"
                            SnapsToDevicePixels="True">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <TextBlock Name="tbContent" Text="off" Margin="5,0,0,0" Style="{StaticResource HeaderTextStyle}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource OnCheckedSb}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource OnUNCheckedSb}"/>
                                </Trigger.ExitActions>
                                <Setter Property="Background" TargetName="baseBdr" Value="Green"/>
                                <Setter Property="Text" TargetName="tbContent" Value="on"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="baseBdr" Value="LightGray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="LightGray">
        <Grid Margin="15,10,15,10">
            <Border x:Name="MainBorder">
                <Grid>
                    <Grid Margin="15,5,5,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="35"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="375"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Connection Settings" Style="{StaticResource TitleTextStyle}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Pos Url" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Login Url" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Encode" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="TimeoutSec" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Retry Count" Style="{StaticResource HeaderTextStyle}"/>

                        <TextBox Grid.Row="1" Grid.Column="1" 
                             x:Name="txtPosUrl"
                             Height="24"                                 
                             Style="{StaticResource InputTxtStyle }"                            
                             Text="{Binding Path=PosUrl,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,NotifyOnValidationError=True}"/>

                        <TextBox Grid.Row="2" Grid.Column="1" 
                             Height="24"
                             Style="{StaticResource InputTxtStyle }" 
                             Text="{Binding Path=LoginUrl,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,NotifyOnValidationError=True}"/>

                        <CheckBox Grid.Row="3" Grid.Column="1"                               
                          IsChecked="{Binding Path=IsEncoded,Mode=TwoWay}"
                          HorizontalAlignment="Left"                                                         
                          Style="{StaticResource SliderSwitch}"
                          Margin="0,5,0,0">
                        </CheckBox>

                        <TextBox Grid.Row="4" Grid.Column="1"  
                                             Style="{StaticResource InputTxtStyle }" 
                                             Height="24"
                                             Text="{Binding Path=TimeOut,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,NotifyOnValidationError=True}"/>

                        <TextBox Grid.Row="5" Grid.Column="1"  
                                             Style="{StaticResource InputTxtStyle }" 
                                             Height="24"
                                             Text="{Binding Path=RetryCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,NotifyOnValidationError=True}"/>

                        <StackPanel Orientation="Horizontal" Grid.Row="6" Grid.ColumnSpan="2" VerticalAlignment="top" Margin="0,10,5,0">
                            <Button 
                                Content="Save"                                
                            Width="75" Height="25"                                
                            IsDefault="True"
                            Command="{Binding Path=SaveSettingsCommand}"                                
                            Style="{StaticResource ButtonBlueStyle}"/>

                        </StackPanel>
                    </Grid>                  
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
